# Local environment configuration (mirrors production via env vars only).

# --- Backend / DynamoDB ---
AWS_REGION=sa-east-1
# DynamoDB Local endpoint (leave UNSET in AWS so the SDK uses real DynamoDB).
DYNAMODB_ENDPOINT_URL=http://localhost:8000
# Dummy credentials for DynamoDB/Cognito Local (never used against real AWS).
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local

# --- Frontend ---
# Points at the local API gateway proxy (the backend Lambda endpoint).
NEXT_PUBLIC_API_BASE_URL=http://localhost:5000

# --- Auth (cognito-local; `make up` writes the real values to local/.cognito.env) ---
COGNITO_ENDPOINT_URL=http://localhost:9229
NEXT_PUBLIC_COGNITO_CLIENT_ID=
NEXT_PUBLIC_COGNITO_REGION=sa-east-1
NEXT_PUBLIC_COGNITO_ENDPOINT=http://localhost:9229
