# Local environment configuration (mirrors production via env vars only).

# --- Backend / DynamoDB ---
AWS_REGION=us-east-1
# DynamoDB Local endpoint (leave UNSET in AWS so the SDK uses real DynamoDB).
DYNAMODB_ENDPOINT_URL=http://localhost:8000
# Dummy credentials for DynamoDB Local (never used against real AWS).
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local

# --- Frontend ---
# Points at the local API gateway proxy (the backend Lambda endpoint).
NEXT_PUBLIC_API_BASE_URL=http://localhost:5000

# --- Auth ---
# Local stack runs without Cognito; the backend skips the role check.
AUTH_BYPASS=true
# Cognito (unset locally: the UI disables auth without a client id).
NEXT_PUBLIC_COGNITO_CLIENT_ID=
NEXT_PUBLIC_COGNITO_REGION=us-east-1
