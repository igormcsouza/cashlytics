# Base URL of the Cashlytics backend API.
# Dev: the local backend emulator. Prod: the Lambda / API Gateway URL.
NEXT_PUBLIC_API_BASE_URL=http://localhost:5000

# Cognito. Locally these come from cognito-local (`make up` writes the real
# client id to ../local/.cognito.env); leave NEXT_PUBLIC_COGNITO_CLIENT_ID
# unset to disable auth entirely (e.g. for `npm run dev` without Docker).
NEXT_PUBLIC_COGNITO_CLIENT_ID=
NEXT_PUBLIC_COGNITO_REGION=us-east-1
NEXT_PUBLIC_COGNITO_ENDPOINT=http://localhost:9229
